#!/usr/bin/env bash

if pgrep -f "gpu-screen-recorder" >/dev/null; then
  pkill -INT -f gpu-screen-recorder
  notify-send -u normal -t "$NOTIF_TIMEOUT" "Previous recording stopped" "Recording exited."
  exit 0
fi

set -e

DEFAULT_OUTPUT_DIR="$HOME/Videos/Screen Recording"
DELAY=0
SILENT=0
NOTIF_TIMEOUT=5000
DATE_TIME_FORMAT="+%Y-%m-%d_%H-%M-%S"
OUTPUT_FILE_EXTENSION=".mp4"
CUSTOM_FILENAME=""
RECORD_AUDIO=1 # 1=system | 2=system+mic
FPS=30
RESOLUTION="1920x1080" # 1920x1080 | 2560x1440 | 1280x720 | original
CURSOR="no"
COLOR_RANGE="limited" # limited | full
CLIPBOARD=1           # 1=copy to clipboard after recording

Help() {
  cat <<EOF
Usage: screenrcd [options]

eg:
  Record fullscreen:                        screenrcd
  Record with 5s delay:                     screenrcd --delay 5
  Record to custom dir:                     screenrcd --output-folder ~/MyRecordings
  Record at 144fps:                         screenrcd --fps 144
  Record at QHD:                            screenrcd --resolution 2560x1440
  Record with mic:                          screenrcd --audio

Options:
  -h, --help                                Show help msg.
  -o, --output-folder <dir>                 Save Directory [default: $DEFAULT_OUTPUT_DIR].
  -f, --filename <name>                     Custom filename [default: YYYY-MM-DD_HH-MM-SS.mp4].
  -D, --delay <seconds>                     Countdown Delay [default: $DELAY].
  -s, --silent                              Silent notify.
  -t, --notif-timeout <ms>                  Notification timeout [default: $NOTIF_TIMEOUT].
  -a, --audio                               Include microphone [system audio always recorded].
  -F, --fps <n>                             Frame rate 30-240 [default: $FPS].
  -r, --resolution <WxH>                    1920x1080 | 2560x1440 | 1280x720 | original [default: $RESOLUTION].
  -C, --no-cursor                           Hide cursor in recording.

EOF
}

send_notification() {
  if [ "$SILENT" -eq 1 ]; then
    return 0
  fi

  local output_file="$1"

  if [ "$CLIPBOARD" -eq 1 ]; then
    printf 'file://%s' "$output_file" | wl-copy --type text/uri-list
  fi

  local message="Recording Captured"$'\n'"$(echo "Video saved in $output_file" | fold -s -w 70)"

  local action
  action=$(notify-send -i "video-x-generic" -u normal -a "Screen Recorder" "$message" \
    --action="view=View File" \
    --action="folder=Open Folder" \
    -t "$NOTIF_TIMEOUT")

  case "$action" in
  "view")
    mpv "$output_file"
    ;;
  "folder")
    xdg-open "$(dirname "$output_file")"
    ;;
  *) ;;
  esac
}

run_fullscreen_record() {
  local current_output_file="$1"

  local audio_args="-ac opus -a default_output"
  if [ "$RECORD_AUDIO" -eq 2 ]; then
    audio_args="-ac opus -a default_output|default_input"
  fi

  local res_arg=""
  [ "$RESOLUTION" != "original" ] && res_arg="-s $RESOLUTION"

  for i in {3..1}; do
    notify-send -e \
      -h string:x-canonical-private-synchronous:record_countdown \
      -h int:value:$i \
      -i "computer" \
      "Recording in:" "<span color='#90a4f4' font='26px'><i><b>$i</b></i></span>"
    if pgrep -f "gpu-screen-recorder" >/dev/null; then
      notify-send -u normal -t "$NOTIF_TIMEOUT" "Recording exited" "Stopped before starting."
      exit 0
    fi
    sleep 1
  done

  notify-send -e \
    -h string:x-canonical-private-synchronous:record_countdown \
    -h int:value:0 \
    -i "computer" \
    -t 1 "" ""

  [ "$DELAY" -gt 0 ] && sleep "$DELAY"

  gpu-screen-recorder -w portal -restore-portal-session yes $audio_args -f "$FPS" $res_arg -k h264 -q very_high -cr "$COLOR_RANGE" -cursor "$CURSOR" -o "$current_output_file" || {
    notify-send -u critical -t "$NOTIF_TIMEOUT" "Screen Recorder" "Recording failed!"
    exit 1
  }

  send_notification "$current_output_file"
}

args() {
  local options=$(getopt -o hf:o:D:st:aF:r:C --long help,output-folder:,filename:,delay:,silent,notif-timeout:,audio,fps:,resolution:,no-cursor -- "$@")
  eval set -- "$options"

  while true; do
    case "$1" in
    -h | --help)
      Help
      exit 0
      ;;
    -o | --output-folder)
      shift
      OUTPUT_DIR="$1"
      ;;
    -f | --filename)
      shift
      FILENAME="$1"
      CUSTOM_FILENAME=1
      ;;
    -D | --delay)
      shift
      DELAY="$1"
      ;;
    -s | --silent) SILENT=1 ;;
    -t | --notif-timeout)
      shift
      NOTIF_TIMEOUT="$1"
      ;;
    -a | --audio) RECORD_AUDIO=2 ;;
    -F | --fps)
      shift
      FPS="$1"
      ;;
    -r | --resolution)
      shift
      RESOLUTION="$1"
      ;;
    -C | --no-cursor)
      CURSOR="no"
      ;;
    --)
      shift
      break
      ;;
    *)
      echo "Internal error: unrecognized option '$1'" >&2
      exit 1
      ;;
    esac
    shift
  done
}

OUTPUT_DIR="${OUTPUT_DIR:-$DEFAULT_OUTPUT_DIR}"
[ -z "$CUSTOM_FILENAME" ] && FILENAME="$(date "$DATE_TIME_FORMAT")$OUTPUT_FILE_EXTENSION"

args "$@"
mkdir -p "$OUTPUT_DIR"
FULL_OUTPUT_FILE="$OUTPUT_DIR/$FILENAME"

run_fullscreen_record "$FULL_OUTPUT_FILE"
