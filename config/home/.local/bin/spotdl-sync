#!/usr/bin/env bash

MUSIC_DIR="$HOME/Music"
LOG_FILE="/tmp/spotdl.log"

mkdir -p "$(dirname "$LOG_FILE")"
>"$LOG_FILE"

for dir in "$MUSIC_DIR"/*/; do
  dir="${dir%/}"

  [ ! -d "$dir" ] && continue
  echo -e "---\n$(basename "$dir")"
  spotdl_file_path="$dir/.spotdl"
  query_arg=""
  extra_args=()

  if [ -f "$spotdl_file_path" ]; then
    query_arg="$spotdl_file_path"
  else
    read -p "Enter Spotify URL [press Enter to skip]: " spotify_url

    if [ -z "$spotify_url" ]; then
      echo "Skipping"
      continue
    fi

    if [[ ! $spotify_url =~ ^https://open\.spotify\.com/(track|playlist|album)/ ]]; then
      echo -e "Error: Invalid Spotify URL. Skipping"
      continue
    fi

    query_arg="$spotify_url"
    extra_args+=(--save-file "$spotdl_file_path" --scan-for-songs --overwrite skip)
  fi

  spotdl sync "$query_arg" \
    "${extra_args[@]}" \
    --threads 3 \
    --bitrate 320k \
    --output "$dir" \
    --lyrics genius musixmatch \
    --print-errors --save-errors "$LOG_FILE" 2>&1
done

echo
mpc update
