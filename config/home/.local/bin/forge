#!/usr/bin/env bash

VERSION="1.6.0"
CONFIG_DIR="$HOME/.config/forge"
CONFIG_FILE="$CONFIG_DIR/config"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

mkdir -p "$CONFIG_DIR"

setup_config() {
  echo -e "${BLUE}Forgejo CLI Setup${NC}"

  echo -e "${YELLOW}Select connection type for git operations:${NC}"
  echo "1. HTTPS"
  echo "2. SSH"
  read -p "Choice [1-2]: " PROTOCOL_CHOICE

  case $PROTOCOL_CHOICE in
  1)
    PROTOCOL="https"
    read -p "Enter Forgejo server URL [https://forge.example.com]: " SERVER_URL
    if [[ ! "$SERVER_URL" =~ ^https:// ]]; then
      SERVER_URL="https://$SERVER_URL"
    fi
    ;;
  2)
    PROTOCOL="ssh"
    read -p "Enter Forgejo server hostname [forge.example.com]: " HOSTNAME
    SERVER_URL="https://$HOSTNAME"
    SSH_URL="$HOSTNAME"
    ;;
  *)
    echo -e "${RED}Invalid choice${NC}"
    exit 1
    ;;
  esac

  echo -e "${YELLOW}Generate an API token in your Forgejo instance:${NC}"
  echo "Settings → Applications → Generate New Token"
  read -s -p "Enter your API token: " API_TOKEN
  echo

  if [[ "$PROTOCOL" == "ssh" ]]; then
    cat >"$CONFIG_FILE" <<EOF
PROTOCOL=$PROTOCOL
SERVER_URL=$SERVER_URL
SSH_URL=$SSH_URL
API_TOKEN=$API_TOKEN
EOF
  else
    cat >"$CONFIG_FILE" <<EOF
PROTOCOL=$PROTOCOL
SERVER_URL=$SERVER_URL
API_TOKEN=$API_TOKEN
EOF
  fi

  echo -e "${GREEN}config saved!${NC}"
}

load_config() {
  if [[ ! -f "$CONFIG_FILE" ]]; then
    echo -e "${RED}No config found. Run 'forge auth login' first.${NC}"
    exit 1
  fi
  source "$CONFIG_FILE"
}

api_request() {
  local method="$1"
  local endpoint="$2"
  local data="$3"

  local url="${SERVER_URL}/api/v1${endpoint}"

  local response
  if [[ -n "$data" ]]; then
    response=$(curl -s -X "$method" \
      -H "Authorization: token $API_TOKEN" \
      -H "Content-Type: application/json" \
      -d "$data" \
      "$url")
  else
    response=$(curl -s -X "$method" \
      -H "Authorization: token $API_TOKEN" \
      "$url")
  fi

  if [[ -z "$response" ]]; then
    echo -e "${RED}Error: No response from server${NC}" >&2
    return 1
  fi

  if ! echo "$response" | jq empty 2>/dev/null; then
    echo -e "${RED}Error: Invalid response from server${NC}" >&2
    echo "Response: $response" >&2
    echo "URL: $url" >&2
    return 1
  fi

  echo "$response"
}

date_relative() {
  local iso_date="$1"

  local updated_epoch

  if command -v gdate >/dev/null 2>&1; then
    updated_epoch=$(gdate -d "$iso_date" +%s 2>/dev/null)
  elif command -v date >/dev/null 2>&1; then
    updated_epoch=$(date -d "$iso_date" +%s 2>/dev/null || date -j -f "%Y-%m-%dT%H:%M:%S" "${iso_date%+*}" +%s 2>/dev/null)
  fi

  if [[ -z "$updated_epoch" || ! "$updated_epoch" =~ ^[0-9]+$ ]]; then
    echo "unknown"
    return
  fi

  local current_epoch=$(date +%s)
  local diff=$((current_epoch - updated_epoch))

  if [[ $diff -lt 0 ]]; then
    echo "just now"
  elif [[ $diff -lt 60 ]]; then
    echo "about ${diff} seconds ago"
  elif [[ $diff -lt 3600 ]]; then
    local minutes=$((diff / 60))
    if [[ $minutes -eq 1 ]]; then
      echo "about 1 minute ago"
    else
      echo "about ${minutes} minutes ago"
    fi
  elif [[ $diff -lt 86400 ]]; then
    local hours=$((diff / 3600))
    if [[ $hours -eq 1 ]]; then
      echo "about 1 hour ago"
    else
      echo "about ${hours} hours ago"
    fi
  elif [[ $diff -lt 2592000 ]]; then
    local days=$((diff / 86400))
    if [[ $days -eq 1 ]]; then
      echo "about 1 day ago"
    else
      echo "about ${days} days ago"
    fi
  elif [[ $diff -lt 31536000 ]]; then
    local months=$((diff / 2592000))
    if [[ $months -eq 1 ]]; then
      echo "about 1 month ago"
    else
      echo "about ${months} months ago"
    fi
  else
    local years=$((diff / 31536000))
    if [[ $years -eq 1 ]]; then
      echo "about 1 year ago"
    else
      echo "about ${years} years ago"
    fi
  fi
}

auth_status() {
  if [[ ! -f "$CONFIG_FILE" ]]; then
    echo -e "${RED}✗ Not logged in${NC}"
    echo "Run 'forge auth login' to authenticate"
    return 1
  fi

  source "$CONFIG_FILE"
  local user_info=$(api_request "GET" "/user" 2>/dev/null)

  if [[ $? -eq 0 ]]; then
    local username=$(echo "$user_info" | jq -r '.login // "Unknown"')
    local email=$(echo "$user_info" | jq -r '.email // "No email"')
    echo -e "${GREEN}✓ Logged in to $SERVER_URL as ${BLUE}$username${NC}"
    echo -e "Email: $email"
    echo -e "Protocol: $PROTOCOL"
  else
    echo -e "${RED}✗ Authentication failed${NC}"
    echo "Token may be invalid. Run 'forge auth login' to re-authenticate"
    return 1
  fi
}

repo_list() {
  local result=$(api_request "GET" "/user/repos")
  if [[ $? -ne 0 ]]; then
    return 1
  fi

  local user_info=$(api_request "GET" "/user")
  if [[ $? -ne 0 ]]; then
    echo -e "${RED}Error: Could not fetch user information${NC}"
    return 1
  fi

  local username=$(echo "$user_info" | jq -r '.login // "Unknown"')
  local repo_count=$(echo "$result" | jq '. | length')

  echo
  echo -e "Showing $repo_count of $repo_count repositories in ${YELLOW}@${GREEN}$username${NC}"
  echo

  local sorted_result=$(echo "$result" | jq 'sort_by(.name)')
  local i=0
  local total=$(echo "$sorted_result" | jq '. | length')

  while [[ $i -lt $total ]]; do
    local name=$(echo "$sorted_result" | jq -r ".[$i].name")
    local desc=$(echo "$sorted_result" | jq -r ".[$i].description // \"\"")
    local updated=$(echo "$sorted_result" | jq -r ".[$i].updated_at")

    if [[ -n "$name" && "$name" != "null" ]]; then
      local rel_time=$(date_relative "$updated")
      printf "\033[0;34m%-25s\033[0m \t%-70s\t\033[38;2;128;135;162m%s\033[0m\n" "$name" "$desc" "$rel_time"
    fi

    ((i++))
  done
}

repo_create() {
  local name=""
  local description=""
  local private="false"

  while [[ $# -gt 0 ]]; do
    case $1 in
    --private)
      private="true"
      shift
      ;;
    --public)
      private="false"
      shift
      ;;
    -*)
      echo -e "${RED}Unknown option: $1${NC}"
      echo "Usage: forge repo create <name> [description] [--private|--public]"
      return 1
      ;;
    *)
      if [[ -z "$name" ]]; then
        name="$1"
      elif [[ -z "$description" ]]; then
        description="$1"
      fi
      shift
      ;;
    esac
  done

  if [[ -z "$name" ]]; then
    read -p "Repository name: " name
  fi

  if [[ -z "$description" ]]; then
    read -p "Description (optional): " description
  fi

  local data="{\"name\":\"$name\",\"description\":\"$description\",\"private\":$private}"

  local result=$(api_request "POST" "/user/repos" "$data")
  if [[ $? -eq 0 ]]; then
    local clone_url=$(echo "$result" | jq -r '.clone_url')

    if [[ "$clone_url" != "null" ]]; then
      echo -e "${GREEN}Repository created successfully!${NC}"
      echo "Clone URL: $clone_url"
      if [[ "$private" == "true" ]]; then
        echo -e "${YELLOW}Repository is private${NC}"
      else
        echo -e "${BLUE}Repository is public${NC}"
      fi
    else
      echo -e "${RED}Failed to create repository${NC}"
      echo "$result" | jq -r '.message // .'
    fi
  fi
}

repo_delete() {
  local repo="$1"
  local force="false"

  while [[ $# -gt 0 ]]; do
    case $1 in
    -f | --force)
      force="true"
      shift
      ;;
    -*)
      echo -e "${RED}Unknown option: $1${NC}"
      echo "Usage: forge repo delete <owner/repo> [--force]"
      return 1
      ;;
    *)
      repo="$1"
      shift
      ;;
    esac
  done

  if [[ -z "$repo" ]]; then
    echo -e "${RED}Usage: forge repo delete <owner/repo> [--force]${NC}"
    return 1
  fi

  local original_repo="$repo"

  if [[ ! "$repo" == *"/"* ]]; then
    local user_info=$(api_request "GET" "/user")
    local username=$(echo "$user_info" | jq -r '.login // "Unknown"')
    repo="$username/$repo"
  fi

  local repo_info=$(api_request "GET" "/repos/$repo" 2>/dev/null)
  if [[ $? -ne 0 ]]; then
    echo -e "${RED}Repository '$repo' not found${NC}"
    return 1
  fi

  local repo_name=$(echo "$repo_info" | jq -r '.name')
  local is_private=$(echo "$repo_info" | jq -r '.private')

  if [[ "$force" != "true" ]]; then
    echo -e "${RED}  ${YELLOW}You are about to delete repository ${RED}$repo${NC}"
    if [[ "$is_private" == "true" ]]; then
      echo -e "${YELLOW}   This is a PRIVATE repository${NC}"
    else
      echo -e "${YELLOW}   This is a PUBLIC repository${NC}"
    fi
    echo -e "${RED}   This action CANNOT be undone!${NC}"
    echo
    read -p "Type '$original_repo' to confirm deletion: " confirm_name
    if [[ "$confirm_name" != "$original_repo" ]]; then
      echo -e "${RED}Repository name confirmation failed. Deletion cancelled.${NC}"
      return 1
    fi
  fi

  echo -e "${BLUE}Deleting repository $repo...${NC}"
  local url="${SERVER_URL}/api/v1/repos/$repo"
  local status_code=$(curl -s -w "%{http_code}" -o /dev/null -X DELETE \
    -H "Authorization: token $API_TOKEN" \
    "$url")

  if [[ "$status_code" -eq 204 || "$status_code" -eq 200 ]]; then
    echo -e "${GREEN}✓ Repository '$repo' has been deleted successfully${NC}"
  else
    echo -e "${RED}✗ Failed to delete repository '$repo' (HTTP $status_code)${NC}"
    return 1
  fi
}

repo_clone() {
  local repo="$1"
  local target_dir="$2"

  if [[ -z "$repo" ]]; then
    echo -e "${RED}Usage: forge repo clone <owner/repo> [directory]${NC}"
    exit 1
  fi

  if [[ ! "$repo" == *"/"* ]]; then
    local user_info=$(api_request "GET" "/user")
    local username=$(echo "$user_info" | jq -r '.login // "Unknown"')
    repo="$username/$repo"
  fi

  local repo_info=$(api_request "GET" "/repos/$repo")
  if [[ $? -eq 0 ]]; then
    local clone_url

    if [[ "$PROTOCOL" == "ssh" ]]; then
      clone_url=$(echo "$repo_info" | jq -r '.ssh_url')
    else
      clone_url=$(echo "$repo_info" | jq -r '.clone_url')
    fi

    if [[ "$clone_url" != "null" ]]; then
      echo -e "${BLUE}Cloning $repo...${NC}"
      if [[ -n "$target_dir" ]]; then
        git clone "$clone_url" "$target_dir"
      else
        git clone "$clone_url"
      fi
    else
      echo -e "${RED}Repository not found${NC}"
    fi
  fi
}

issue_list() {
  local repo="$1"

  if [[ -z "$repo" ]]; then
    repo=$(git remote get-url origin 2>/dev/null | sed -n 's/.*[:/]\([^/]*\/[^/]*\)\.git/\1/p')
    if [[ -z "$repo" ]]; then
      echo -e "${RED}Usage: forge issue list <owner/repo> or run from a git repository${NC}"
      exit 1
    fi
  fi

  echo -e "${BLUE}Issues in $repo:${NC}"
  local result=$(api_request "GET" "/repos/$repo/issues")
  if [[ $? -eq 0 ]]; then
    echo "$result" | jq -r '.[] | "#\(.number) \(.title) (\(.state))"'
  fi
}

pr_list() {
  local repo="$1"

  if [[ -z "$repo" ]]; then
    repo=$(git remote get-url origin 2>/dev/null | sed -n 's/.*[:/]\([^/]*\/[^/]*\)\.git/\1/p')
    if [[ -z "$repo" ]]; then
      echo -e "${RED}Usage: forge pr list <owner/repo> or run from a git repository${NC}"
      exit 1
    fi
  fi

  echo -e "${BLUE}Pull requests in $repo:${NC}"
  local result=$(api_request "GET" "/repos/$repo/pulls")
  if [[ $? -eq 0 ]]; then
    echo "$result" | jq -r '.[] | "#\(.number) \(.title) (\(.state))"'
  fi
}

browse() {
  local repo="$1"

  if [[ -z "$repo" ]]; then
    repo=$(git remote get-url origin 2>/dev/null | sed -n 's/.*[:/]\([^/]*\/[^/]*\)\.git/\1/p')
    if [[ -z "$repo" ]]; then
      echo -e "${RED}Usage: forge browse <owner/repo> or run from a git repository${NC}"
      exit 1
    fi
  fi

  local url="$SERVER_URL/$repo"

  if command -v xdg-open >/dev/null; then
    xdg-open "$url"
  elif command -v open >/dev/null; then
    open "$url"
  else
    echo "Open in browser: $url"
  fi
}

get_bash_completion() {
  cat <<'BASH_COMPLETION_EOF'
_forge_completion() {
    local cur prev words cword
    _init_completion || return
    local commands="auth repo issue pr browse config install help version"
    local auth_commands="login setup status"
    local repo_commands="list ls create clone delete del"
    local issue_commands="list ls"
    local pr_commands="list ls"
    local config_commands="show"
    local install_commands="bash zsh fish"
    local global_flags="-h --help"
    
    # Global flags are always available
    if [[ "$cur" == -* ]]; then
        COMPREPLY=($(compgen -W "$global_flags" -- "$cur"))
        return 0
    fi
    
    if [[ $cword -eq 1 ]]; then
        COMPREPLY=($(compgen -W "$commands" -- "$cur"))
        return 0
    fi
    case "${words[1]}" in
        auth)
            if [[ $cword -eq 2 ]]; then
                COMPREPLY=($(compgen -W "$auth_commands" -- "$cur"))
            fi
            ;;
        repo)
            if [[ $cword -eq 2 ]]; then
                COMPREPLY=($(compgen -W "$repo_commands" -- "$cur"))
            elif [[ $cword -gt 2 ]]; then
                case "${words[2]}" in
                    create)
                        if [[ "$cur" == --* ]]; then
                            COMPREPLY=($(compgen -W "--private --public" -- "$cur"))
                        fi
                        ;;
                    delete|del)
                        if [[ "$cur" == -* ]]; then
                            COMPREPLY=($(compgen -W "--force -f" -- "$cur"))
                        fi
                        ;;
                esac
            fi
            ;;
        issue)
            if [[ $cword -eq 2 ]]; then
                COMPREPLY=($(compgen -W "$issue_commands" -- "$cur"))
            fi
            ;;
        pr)
            if [[ $cword -eq 2 ]]; then
                COMPREPLY=($(compgen -W "$pr_commands" -- "$cur"))
            fi
            ;;
        config)
            if [[ $cword -eq 2 ]]; then
                COMPREPLY=($(compgen -W "$config_commands" -- "$cur"))
            fi
            ;;
        install)
            if [[ $cword -eq 2 ]]; then
                COMPREPLY=($(compgen -W "$install_commands" -- "$cur"))
            fi
            ;;
    esac
}
complete -F _forge_completion forge
BASH_COMPLETION_EOF
}

get_zsh_completion() {
  cat <<'ZSH_COMPLETION_EOF'
#compdef forge
_forge() {
    local state line
    typeset -A opt_args
    _arguments -C \
        '(-h --help)'{-h,--help}'[Show help]' \
        '1: :_forge_commands' \
        '*:: :->args' \
        && return 0
    case $state in
        args)
            case $words[1] in
                auth)
                    _arguments \
                        '(-h --help)'{-h,--help}'[Show help]' \
                        '1: :(login setup status)'
                    ;;
                repo)
                    _forge_repo
                    ;;
                issue)
                    _arguments \
                        '(-h --help)'{-h,--help}'[Show help]' \
                        '1: :(list ls)'
                    ;;
                pr)
                    _arguments \
                        '(-h --help)'{-h,--help}'[Show help]' \
                        '1: :(list ls)'
                    ;;
                config)
                    _arguments \
                        '(-h --help)'{-h,--help}'[Show help]' \
                        '1: :(show)'
                    ;;
                install)
                    _arguments \
                        '(-h --help)'{-h,--help}'[Show help]' \
                        '1: :(bash zsh fish)' \
                        '2:path:_files -/'
                    ;;
            esac
            ;;
    esac
}
_forge_commands() {
    local commands
    commands=(
        'auth:Authenticate forge with Forgejo'
        'repo:Manage repositories'
        'issue:Manage issues'
        'pr:Manage pull requests'
        'browse:Open repositories in browser'
        'config:Manage config'
        'install:Install shell completion'
        'help:Show help'
        'version:Show version'
    )
    _describe 'command' commands
}
_forge_repo() {
    _arguments -C \
        '(-h --help)'{-h,--help}'[Show help]' \
        '1: :_forge_repo_commands' \
        '*:: :->repo_args' \
        && return 0
    case $state in
        repo_args)
            case $words[1] in
                create)
                    _arguments \
                        '(-h --help)'{-h,--help}'[Show help]' \
                        '--private[Create private repository]' \
                        '--public[Create public repository]' \
                        '1:name:' \
                        '2:description:'
                    ;;
                delete|del)
                    _arguments \
                        '(-h --help)'{-h,--help}'[Show help]' \
                        '(-f --force)'{-f,--force}'[Skip confirmation]' \
                        '1:repository:'
                    ;;
                clone)
                    _arguments \
                        '(-h --help)'{-h,--help}'[Show help]' \
                        '1:repository:' \
                        '2:directory:'
                    ;;
            esac
            ;;
    esac
}
_forge_repo_commands() {
    local repo_commands
    repo_commands=(
        'list:List repositories'
        'ls:List repositories'
        'create:Create repository'
        'clone:Clone repository'
        'delete:Delete repository'
        'del:Delete repository'
    )
    _describe 'repo command' repo_commands
}
_forge "$@"
ZSH_COMPLETION_EOF
}

get_fish_completion() {
  cat <<'FISH_COMPLETION_EOF'
complete -c forge -f
complete -c forge -s h -l help -d 'Show help'

complete -c forge -n '__fish_use_subcommand' -a 'auth' -d 'Authenticate forge with Forgejo'
complete -c forge -n '__fish_use_subcommand' -a 'repo' -d 'Manage repositories'
complete -c forge -n '__fish_use_subcommand' -a 'issue' -d 'Manage issues'
complete -c forge -n '__fish_use_subcommand' -a 'pr' -d 'Manage pull requests'
complete -c forge -n '__fish_use_subcommand' -a 'browse' -d 'Open repositories in browser'
complete -c forge -n '__fish_use_subcommand' -a 'config' -d 'Manage config'
complete -c forge -n '__fish_use_subcommand' -a 'install' -d 'Install shell completion'
complete -c forge -n '__fish_use_subcommand' -a 'help' -d 'Show help'
complete -c forge -n '__fish_use_subcommand' -a 'version' -d 'Show version'

complete -c forge -n '__fish_seen_subcommand_from auth' -s h -l help -d 'Show help'
complete -c forge -n '__fish_seen_subcommand_from auth' -a 'login' -d 'Set up authentication'
complete -c forge -n '__fish_seen_subcommand_from auth' -a 'setup' -d 'Set up authentication'
complete -c forge -n '__fish_seen_subcommand_from auth' -a 'status' -d 'Show authentication status'

complete -c forge -n '__fish_seen_subcommand_from repo' -s h -l help -d 'Show help'
complete -c forge -n '__fish_seen_subcommand_from repo' -a 'list' -d 'List repositories'
complete -c forge -n '__fish_seen_subcommand_from repo' -a 'ls' -d 'List repositories'
complete -c forge -n '__fish_seen_subcommand_from repo' -a 'create' -d 'Create repository'
complete -c forge -n '__fish_seen_subcommand_from repo' -a 'clone' -d 'Clone repository'
complete -c forge -n '__fish_seen_subcommand_from repo' -a 'delete' -d 'Delete repository'
complete -c forge -n '__fish_seen_subcommand_from repo' -a 'del' -d 'Delete repository'

complete -c forge -n '__fish_seen_subcommand_from repo; and __fish_seen_subcommand_from create' -s h -l help -d 'Show help'
complete -c forge -n '__fish_seen_subcommand_from repo; and __fish_seen_subcommand_from create' -l 'private' -d 'Create private repository'
complete -c forge -n '__fish_seen_subcommand_from repo; and __fish_seen_subcommand_from create' -l 'public' -d 'Create public repository'

complete -c forge -n '__fish_seen_subcommand_from repo; and __fish_seen_subcommand_from delete del' -s h -l help -d 'Show help'
complete -c forge -n '__fish_seen_subcommand_from repo; and __fish_seen_subcommand_from delete del' -s 'f' -l 'force' -d 'Skip confirmation'

complete -c forge -n '__fish_seen_subcommand_from issue' -s h -l help -d 'Show help'
complete -c forge -n '__fish_seen_subcommand_from issue' -a 'list' -d 'List issues'
complete -c forge -n '__fish_seen_subcommand_from issue' -a 'ls' -d 'List issues'

complete -c forge -n '__fish_seen_subcommand_from pr' -s h -l help -d 'Show help'
complete -c forge -n '__fish_seen_subcommand_from pr' -a 'list' -d 'List pull requests'
complete -c forge -n '__fish_seen_subcommand_from pr' -a 'ls' -d 'List pull requests'

complete -c forge -n '__fish_seen_subcommand_from config' -s h -l help -d 'Show help'
complete -c forge -n '__fish_seen_subcommand_from config' -a 'show' -d 'Show config'

complete -c forge -n '__fish_seen_subcommand_from install' -s h -l help -d 'Show help'
complete -c forge -n '__fish_seen_subcommand_from install' -a 'bash' -d 'Install bash completion'
complete -c forge -n '__fish_seen_subcommand_from install' -a 'zsh' -d 'Install zsh completion'
complete -c forge -n '__fish_seen_subcommand_from install' -a 'fish' -d 'Install fish completion'
FISH_COMPLETION_EOF
}

install_completion() {
  local shell="$1"
  local custom_path="$2"
  case "$shell" in
  bash)
    local completion_file="forge"
    local completion_path="${custom_path:-/usr/share/bash-completion/completions}"
    completion_path="${completion_path%/}"

    if [[ -z "$custom_path" ]]; then
      if [[ ! -d "$completion_path" ]]; then
        echo -e "${YELLOW}System directory $completion_path doesn't exist${NC}"
        echo -e "${YELLOW}Attempting to create with sudo...${NC}"
        if ! sudo mkdir -p "$completion_path" 2>/dev/null; then
          echo -e "${YELLOW}Failed to create system directory, falling back to user directory${NC}"
          completion_path="$HOME/.local/share/bash-completion/completions"
          mkdir -p "$completion_path"
        fi
      fi

      if [[ "$completion_path" == "/usr/share/bash-completion/completions" ]]; then
        if ! sudo bash -c "$(declare -f get_bash_completion); get_bash_completion" >"$completion_path/$completion_file" 2>/dev/null; then
          echo -e "${YELLOW}Failed to write to system directory, falling back to user directory${NC}"
          completion_path="$HOME/.local/share/bash-completion/completions"
          mkdir -p "$completion_path"
          get_bash_completion >"$completion_path/$completion_file"
        fi
      else
        get_bash_completion >"$completion_path/$completion_file"
      fi
    else
      mkdir -p "$completion_path"
      get_bash_completion >"$completion_path/$completion_file"
    fi

    echo -e "${GREEN}✓ Bash completion installed to $completion_path/$completion_file${NC}"
    echo "Run 'source ~/.bashrc' or restart your terminal to activate"
    ;;
  zsh)
    local completion_file="_forge"
    local completion_path="${custom_path:-$HOME/.local/share/zsh/completions}"
    completion_path="${completion_path%/}"
    mkdir -p "$completion_path"
    get_zsh_completion >"$completion_path/$completion_file"
    echo -e "${GREEN}✓ Zsh completion installed to $completion_path/$completion_file${NC}"
    echo "Run 'autoload -U compinit && compinit' or restart your terminal to activate"
    ;;
  fish)
    local completion_file="forge.fish"
    local completion_path="${custom_path:-$HOME/.config/fish/completions}"
    completion_path="${completion_path%/}"
    mkdir -p "$completion_path"
    get_fish_completion >"$completion_path/$completion_file"
    echo -e "${GREEN}✓ Fish completion installed to $completion_path/$completion_file${NC}"
    echo "Completion will be available in new fish sessions"
    ;;
  *)
    echo -e "${RED}Unknown shell: $shell${NC}"
    echo "Supported shells: bash, zsh, fish"
    return 1
    ;;
  esac
}

show_help() {
  cat <<'EOF'
Work seamlessly with Forgejo from the command line.

USAGE
  forge <command> <subcommand> [flags]

AUTHENTICATION
  forge auth login          Set up authentication with your Forgejo server
  forge auth status         Show current authentication status

REPOSITORY MANAGEMENT
  forge repo list           List your repositories
  forge repo ls             List your repositories [short form]
  forge repo create <name> [description] [flags]
                            Create a new repository
  forge repo clone <repo> [directory]
                            Clone a repository
  forge repo delete <repo> [flags]
                            Delete a repository

ISSUES & PULL REQUESTS
  forge issue list [repo]   List issues in repository
  forge issue ls [repo]     List issues in repository [short form]
  forge pr list [repo]      List pull requests in repository
  forge pr ls [repo]        List pull requests in repository [short form]

UTILITIES
  forge browse [repo]       Open repository in web browser
  forge install <shell> [path]
                            Install shell completion
  forge config show        Show current config
  forge version            Show version information
  forge help               Show this help message

FLAGS
  Repository creation:
    --private               Create a private repository
    --public                Create a public repository [default]

  Repository deletion:
    -f, --force             Skip confirmation prompt

  Global flags:
    -h, --help              Show help for command

EXAMPLES
  Setup and authentication:
    forge auth login
    forge auth status

  Repository operations:
    forge repo list
    forge repo create myproject --private
    forge repo create "My Project" "A sample project" --public
    forge repo clone myproject
    forge repo clone myproject ./custom-dir
    forge repo delete myproject
    forge repo delete myproject --force

  Issues and pull requests:
    forge issue list
    forge issue list owner/repo
    forge pr list
    forge pr list owner/repo

  Shell completion installation:
    forge install bash              # Default: /usr/share/bash-completion/completions/
    forge install zsh               # Default: ~/.local/share/zsh/completions/
    forge install fish              # Default: ~/.config/fish/completions/
    
  Custom installation paths:
    forge install bash /usr/local/share/bash-completion/completions
    forge install zsh ~/.local/share/zsh/completions
    forge install fish ~/.config/fish/completions

  Other utilities:
    forge browse myproject
    forge config show

NOTES
  - Repository names can be specified as 'repo' [assumes current user] or 'owner/repo'
  - When run from a git repository, repo-specific commands will auto-detect the repository
  - Supports both HTTPS and SSH protocols for git operations
  - Requires curl and jq to be installed

LEARN MORE
  Documentation: https://forgejo.org
  Report issues: https://codeberg.org/forgejo/forgejo
EOF
}

case "${1:-help}" in
"auth")
  case "${2:-help}" in
  "login" | "setup")
    setup_config
    ;;
  "status")
    auth_status
    ;;
  *)
    echo "Usage: forge auth {login|status}"
    ;;
  esac
  ;;
"repo")
  load_config
  case "${2:-help}" in
  "list" | "ls")
    repo_list
    ;;
  "create")
    shift 2
    repo_create "$@"
    ;;
  "delete" | "del")
    shift 2
    repo_delete "$@"
    ;;
  "clone")
    repo_clone "$3" "$4"
    ;;
  *)
    echo "Usage: forge repo {list|create|clone|delete}"
    ;;
  esac
  ;;
"issue")
  load_config
  case "${2:-help}" in
  "list" | "ls")
    issue_list "$3"
    ;;
  *)
    echo "Usage: forge issue list [owner/repo]"
    ;;
  esac
  ;;
"pr")
  load_config
  case "${2:-help}" in
  "list" | "ls")
    pr_list "$3"
    ;;
  *)
    echo "Usage: forge pr list [owner/repo]"
    ;;
  esac
  ;;
"browse")
  load_config
  browse "$2"
  ;;
"install")
  case "${2:-help}" in
  "bash" | "zsh" | "fish")
    install_completion "$2" "$3"
    ;;
  *)
    echo "Usage: forge install {bash|zsh|fish} [path]"
    echo "Install shell completion for forge command"
    ;;
  esac
  ;;
"config")
  case "${2:-help}" in
  "show")
    if [[ -f "$CONFIG_FILE" ]]; then
      echo -e "${BLUE}Current config:${NC}"
      cat "$CONFIG_FILE"
    else
      echo -e "${RED}No config found${NC}"
    fi
    ;;
  *)
    echo "Usage: forge config show"
    ;;
  esac
  ;;
"version")
  echo "forge version $VERSION"
  ;;
"help" | "-h" | "--help")
  show_help
  ;;
*)
  show_help
  ;;
esac
