#!/usr/bin/env bash

flag=${1:-"--help"}

help() {
  echo -e "Usage: svr [options]"
  echo -e "  --services  Restart services"
  echo -e "  --upgrade   Pull & update services"
  echo -e "  --prune     Remove unused images/cache"
  echo -e "  --help, -h  Show help"
}

case $flag in
--services | --upgrade | --prune)
  ssh -t server "~/.local/bin/svr $flag"
  ;;
-h | --help | *)
  help
  ;;
esac
