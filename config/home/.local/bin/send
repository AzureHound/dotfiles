#!/usr/bin/env bash

if [[ $# -gt 0 ]]; then
  LOCAL_PATHS=("$@")

  for path in "${LOCAL_PATHS[@]}"; do
    if [[ ! -e "$path" ]]; then
      echo "Error: '$path' does not exist."
      exit 1
    fi
  done
else
  LOCAL_PATH=$(find "$(pwd)" -type f -o -type d 2>/dev/null | fzf --prompt="󰥨 Local Path: ")
  if [[ -z "$LOCAL_PATH" ]]; then
    echo "No file or folder selected. Exiting."
    exit 1
  fi
  LOCAL_PATHS=("$LOCAL_PATH")
fi

read -p "Server IP: " REMOTE_SERVER
read -p "Directory: " REMOTE_DIR

echo "You selected: ${LOCAL_PATHS[*]}"
echo "Sending ${LOCAL_PATHS[*]} to $REMOTE_SERVER:$REMOTE_DIR"

rsync -rhPz "${LOCAL_PATHS[@]}" "$REMOTE_SERVER:$REMOTE_DIR"

if [[ $? -eq 0 ]]; then
  echo "Successful"
else
  echo "Failed!"
fi
